# New Agent service
TAX_AGENT_ENV=local
TAX_AGENT_LOG_LEVEL=INFO
TAX_AGENT_HOST=0.0.0.0
TAX_AGENT_PORT=8011

# Old backend, used while API redirect is in transition
LEGACY_BACKEND_BASE_URL=http://127.0.0.1:8001

# OpenAI-compatible model provider, e.g. Qwen DashScope compatible endpoint
LLM_MODEL=qwen-plus
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.3

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1536

# RAG storage
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=agno
PG_KNOWLEDGE_SCHEMA=knowledge

# Feature switches
ENABLE_REAL_LLM=false
ENABLE_REAL_RAG=false
ENABLE_LANGSMITH=false
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
