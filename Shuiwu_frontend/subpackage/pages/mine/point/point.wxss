.page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 48rpx;
}

.hero {
  padding: 48rpx 32rpx 64rpx;
  background: linear-gradient(135deg, #4f46e5, #6366f1);
  color: #ffffff;
}

.hero-content {
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.balance-card {
  border-radius: 18rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.balance-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.balance-value {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.balance-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.85;
}

.summary {
  margin: 18rpx 24rpx 0;
  font-size: 24rpx;
  color: #64748b;
}

.list-card {
  margin: 16rpx 24rpx 0;
}

.record-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.record-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.record-extra {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.record-side {
  text-align: right;
  min-width: 140rpx;
}

.record-points {
  font-size: 30rpx;
  font-weight: 700;
}

.points-positive {
  color: #16a34a;
}

.points-negative {
  color: #dc2626;
}

.points-neutral {
  color: #334155;
}

.record-balance {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.loading-block,
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.no-more {
  text-align: center;
  padding: 16rpx 0;
  font-size: 22rpx;
  color: #94a3b8;
}

.empty-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 0;
}
