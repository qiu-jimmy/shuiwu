<!--subpackage/pages/mine/point/point.wxml-->
<view class="page">
  <view class="hero">
    <view class="hero-content">
      <text class="hero-title">积分明细</text>
      <text class="hero-desc">查看积分变动与余额</text>
    </view>
    <view class="balance-card">
      <view class="balance-label">当前积分</view>
      <view class="balance-value">{{balanceLabel}}</view>
      <view class="balance-meta" wx:if="{{lastUpdatedLabel}}">
        <text class="balance-time">更新于 {{lastUpdatedLabel}}</text>
      </view>
    </view>
  </view>

  <view class="summary">共 {{total}} 条记录</view>

  <view class="list-card">
    <view wx:if="{{loading && !records.length}}" class="loading-block">
      <t-loading size="40rpx" />
      <text class="loading-text">加载积分记录中...</text>
    </view>

    <view wx:elif="{{records.length}}">
      <block wx:for="{{records}}" wx:key="record_id">
        <view class="record-card">
          <view class="record-main">
            <view class="record-title-row">
              <text class="record-title">{{item.title}}</text>
              <t-tag size="small" variant="light" theme="{{item.tagTheme}}">
                {{item.changeTypeLabel}}
              </t-tag>
            </view>
            <view class="record-meta">{{item.createdLabel}}</view>
            <view class="record-extra" wx:if="{{item.relatedLabel}}">{{item.relatedLabel}}</view>
          </view>
          <view class="record-side">
            <text class="record-points {{item.pointsClass}}">{{item.pointsLabel}}</text>
            <text class="record-balance">余额 {{item.balanceLabel}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{loading && records.length}}" class="loading-more">
        <t-loading size="32rpx" />
        <text class="loading-text">加载更多</text>
      </view>
      <view wx:elif="{{!hasMore}}" class="no-more">没有更多积分记录</view>
    </view>

    <view wx:else class="empty-block">
      <t-empty description="暂无积分记录" />
    </view>
  </view>
</view>
