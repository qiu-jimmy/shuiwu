/* pages/mine/vip-center/vip-center.wxss */
.page {
  min-height: 100vh;
  background: #f4f6fb;
  color: #0f172a;
}

.hero {
  padding: 48rpx 32rpx 140rpx;
  background: linear-gradient(135deg, #2156f3 0%, #5a7dff 100%);
  color: #ffffff;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.content {
  margin-top: -90rpx;
  padding: 0 24rpx 60rpx;
}

.card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.summary-card {
  padding: 28rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.summary-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-level {
  font-size: 34rpx;
  font-weight: 700;
}

.summary-package {
  font-size: 24rpx;
  color: #64748b;
}

.summary-meta {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.meta-value {
  font-size: 24rpx;
  color: #1f2937;
  word-break: break-all;
}

.summary-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}

.summary-action {
  flex: 1;
}

.card-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
}

.card-subtitle {
  font-size: 22rpx;
  color: #64748b;
}

.cell-group {
  background: transparent;
}

.cell-title {
  font-size: 24rpx;
  color: #475569;
}

.cell-note {
  font-size: 24rpx;
  color: #1f2937;
}

.usage-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.usage-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.usage-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.usage-label {
  font-size: 24rpx;
  color: #1f2937;
}

.usage-value {
  font-size: 24rpx;
  color: #64748b;
}

.usage-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #94a3b8;
}

.usage-tag-row {
  display: flex;
  align-items: center;
}

.feature-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  border: 2rpx solid #e7edf6;
}

.feature-name {
  font-size: 24rpx;
  color: #1f2937;
}

.loading-block {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 80rpx 0;
}

.loading-block--inner {
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #64748b;
}

.stats-empty {
  text-align: center;
  padding: 16rpx 0;
}

.stats-empty-text {
  font-size: 22rpx;
  color: #94a3b8;
}

.empty-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 16rpx 30rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.empty-desc {
  font-size: 24rpx;
  color: #64748b;
}
