/* pages/mine/mcp-manager/mcp-manager.wxss */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F7FA 0%, #FFFFFF 100%);
}

.hero {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.content {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.card-header {
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F1F1F;
}

.status-card {
  padding: 32rpx;
}

.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F1F1F;
}

.status-desc {
  margin-bottom: 24rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.status-action {
  display: flex;
  justify-content: flex-start;
}

.tools-list {
  padding: 16rpx 0;
}

.tool-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.tool-item:last-child {
  border-bottom: none;
}

.tool-info {
  flex: 1;
  margin-right: 24rpx;
}

.tool-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1F1F1F;
}

.tool-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.tool-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
}

.tool-action {
  flex-shrink: 0;
}

.guide-list {
  padding: 24rpx 32rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 40rpx;
}

.empty-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 80rpx 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #1F1F1F;
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

.loading-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-block--inner {
  padding: 40rpx 0;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999999;
}

.empty-state {
  padding: 60rpx 0;
}
