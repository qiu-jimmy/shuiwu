/* pages/mine/question/question.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  margin: 8rpx 8rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  display: flex;
  flex-direction: column;
}

.list-card {
  padding-top: 8rpx;
}

.filter-tabs {
  margin: 0 -8rpx 8rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-field {
  margin-bottom: 24rpx;
}

.loading-block,
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.question-item {
  padding: 20rpx 0;
}

.question-item + .question-item {
  border-top: 1rpx solid #f1f5f9;
}

.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.question-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.question-desc {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
  word-break: break-all;
}

.reply-block {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reply-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
}

.reply-content {
  font-size: 24rpx;
  color: #1f2937;
  line-height: 1.5;
}

.reply-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.question-meta {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.question-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.empty-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 0;
}

.no-more {
  text-align: center;
  padding: 16rpx 0;
  font-size: 22rpx;
  color: #94a3b8;
}
