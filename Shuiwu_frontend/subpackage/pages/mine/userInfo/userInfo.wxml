<!--pages/mine/userInfo/userInfo.wxml-->
<view class="page">
  <view class="cover">
    <image class="cover-image" src="{{coverUrl}}" mode="aspectFill" />
    <view class="cover-mask"></view>
  </view>

  <view class="content">
    <view wx:if="{{isLogin}}">
      <view class="profile-panel">
        <view class="avatar-wrap" bind:tap="onAvatarTap">
          <t-avatar
            wx:if="{{avatarUrl}}"
            class="profile-avatar"
            image="{{avatarUrl}}"
            size="160rpx"
            shape="circle"
            bordered
          />
          <t-avatar
            wx:else
            class="profile-avatar"
            icon="user"
            size="160rpx"
            shape="circle"
            bordered
          />
          <view class="avatar-overlay">更换头像</view>
        </view>
        <view class="profile-meta">
          <text class="profile-name">{{display.name}}</text>
          <text class="profile-phone">{{display.phone}}</text>
          <view class="profile-tags">
            <text class="profile-tag">{{display.member_package_name}}</text>
            <text class="profile-tag">{{display.userType}}</text>
            <text class="profile-tag">{{display.status}}</text>
          </view>
        </view>
      </view>

      <t-cell-group class="info-group">
        <t-cell
          wx:for="{{infoItems}}"
          wx:key="label"
          title="{{item.label}}"
          note="{{item.value}}"
          arrow="{{item.editable}}"
          t-class-title="info-title"
          t-class-note="info-note"
          bind:tap="onInfoItemTap"
          data-action="{{item.action}}"
        />
      </t-cell-group>
    </view>

    <view wx:else class="empty-card">
      <text class="empty-title">未登录</text>
      <text class="empty-desc">登录后可查看完整的个人信息</text>
      <view class="empty-action">
        <t-button theme="primary" block bind:tap="onLoginTap">去登录</t-button>
      </view>
    </view>
  </view>
</view>

<t-popup
  visible="{{nicknameVisible}}"
  placement="center"
  animation="none"
  bind:close="onNicknameClose"
>
  <view class="form-card">
    <view class="form-header">
      <text class="form-title">修改昵称</text>
    </view>

    <t-input
      value="{{formNickname}}"
      placeholder="请输入昵称"
      clearable
      bind:change="onNicknameChange"
    />

    <view class="form-actions">
      <t-button
        variant="outline"
        block
        bind:tap="onNicknameClose"
      >
        取消
      </t-button>

      <t-button
        theme="primary"
        block
        loading="{{updatingNickname}}"
        bind:tap="onNicknameSubmit"
      >
        保存
      </t-button>
    </view>
  </view>
</t-popup>


<t-popup visible="{{phoneVisible}}" placement="center" bind:close="onPhoneClose">
  <view class="form-card">
    <view class="form-header">
      <text class="form-title">绑定/更换手机号</text>
    </view>
    <view class="form-field">
      <text class="form-label">手机号</text>
      <t-input
        value="{{formPhone}}"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        clearable
        bind:change="onPhoneChange"
      />
    </view>
    <view class="form-actions">
      <t-button variant="outline" block bind:tap="onPhoneClose">取消</t-button>
      <t-button theme="primary" block loading="{{updatingPhone}}" bind:tap="onPhoneSubmit">保存</t-button>
    </view>
  </view>
</t-popup>
