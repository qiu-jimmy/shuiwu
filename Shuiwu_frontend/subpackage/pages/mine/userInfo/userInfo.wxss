.cover {
  position: relative;
  height: 320rpx;
  z-index: -1;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.content {
  padding: 0 24rpx 48rpx;
  margin-top: -120rpx;
}

.profile-panel {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.12);
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 999rpx;
  overflow: hidden;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
}

.avatar-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.3);
}

.profile-meta {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.profile-phone {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.profile-tag {
  padding: 6rpx 12rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #2563eb;
  background: rgba(37, 99, 235, 0.12);
}

.info-group {
  margin-top: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.08);
}

.info-title {
  color: #94a3b8;
  font-size: 24rpx;
}

.info-note {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}

.info-right {
  align-items: center;
}

.empty-card {
  margin-top: 120rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.08);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.empty-action {
  margin-top: 20rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  width: 640rpx;
  max-width: 90vw;
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.form-field {
  margin-bottom: 16rpx;
}

.form-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.form-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 16rpx;
}

.form-actions t-button {
  flex: 1;
}
