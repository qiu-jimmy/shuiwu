/* pages/mine/password/password.wxss */
.page {
  min-height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  color: #0f172a;
  font-family: "Alibaba PuHuiTi", "FZLanTingHeiS", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.card {
  padding: 28rpx 26rpx 30rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.08);
}

.card-header {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.form {
  margin-top: 22rpx;
}

.form-item {
  margin-top: 16rpx;
}

.form-item:first-child {
  margin-top: 0;
}

.actions {
  margin-top: 24rpx;
}
