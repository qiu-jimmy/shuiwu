<!--pages/mine/password/password.wxml-->
<view class="page">
  <view class="card">
    <view class="card-header">
      <text class="card-title">修改密码</text>
      <text class="card-desc">请使用 6-20 位字符并包含字母与数字</text>
    </view>

    <view class="form">
      <view class="form-item">
        <t-input
          label="当前密码"
          layout="vertical"
          placeholder="请输入当前密码"
          type="password"
          value="{{form.oldPassword}}"
          data-field="oldPassword"
          bind:change="onInputChange"
        />
      </view>
      <view class="form-item">
        <t-input
          label="新密码"
          layout="vertical"
          placeholder="请输入新密码"
          type="password"
          value="{{form.newPassword}}"
          data-field="newPassword"
          bind:change="onInputChange"
        />
      </view>
      <view class="form-item">
        <t-input
          label="确认新密码"
          layout="vertical"
          placeholder="再次输入新密码"
          type="password"
          value="{{form.confirmPassword}}"
          data-field="confirmPassword"
          bind:change="onInputChange"
        />
      </view>
    </view>

    <view class="actions">
      <t-button
        theme="light"
        block
        loading="{{loading}}"
        disabled="{{loading}}"
        bind:tap="onSubmit"
      >保存修改</t-button>
    </view>
  </view>
</view>
