<view class="page">
  <view class="content">
    <block wx:if="{{loading}}">
      <view class="loading-block">
        <t-loading size="16" />
        <text class="loading-text">加载中</text>
      </view>
    </block>
    <block wx:elif="{{packages.length}}">
      <view class="section">
        <view class="section-title">选择VIP版本</view>
        <view class="plan-grid">
          <block wx:for="{{versionOptions}}" wx:key="versionKey">
            <view class="plan-card {{selectedVersionKey === item.versionKey ? 'is-active' : ''}}" data-version-key="{{item.versionKey}}" bindtap="onPackageSelect">
              <text class="plan-name">{{item.name}}</text>
            </view>
          </block>
        </view>
      </view>

      <view class="section">
        <view class="feature-card">
          <block wx:for="{{packages}}" wx:key="package_id">
            <view wx:if="{{item.package_id === selectedPackageId}}" class="feature-body">
              <view class="feature-title">会员享<text style="color: #065ace;">专属功能</text></view>
              <view class="feature-list">
                <block wx:if="{{item.benefits && item.benefits.length}}">
                  <block wx:for="{{item.benefits}}" wx:for-item="benefit" wx:key="index">
                    <view class="feature-item">
                      <view class="feature-dot"></view>
                      <text class="feature-text">{{benefit.title}}<text wx:if="{{benefit.desc}}">：{{benefit.desc}}</text></text>
                    </view>
                  </block>
                </block>
                <view wx:else class="feature-item">
                  <view class="feature-dot"></view>
                  <text class="feature-text">暂无权益说明</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>

      <view class="section">
        <view class="section-title">订阅方式</view>
        <view class="plan-grid">
          <block wx:for="{{durationOptions}}" wx:key="package_type">
            <view class="plan-card1 {{selectedDurationType === item.package_type ? 'is-active' : ''}}" data-type="{{item.package_type}}" bindtap="onDurationSelect">
              <view class="plan-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
              <text class="plan-name">{{item.name}}</text>
              <view class="plan-price" wx:if="{{item.priceLabel}}">
                <text class="plan-currency">￥</text>
                <text class="plan-amount">{{item.priceLabel}}</text>
              </view>
              <text wx:else class="plan-sub">暂未上架</text>
            </view>
          </block>
        </view>
      </view>

      <view class="section">
        <view class="section-title">支付方式</view>
          <view class="pay-method {{selectedPayMethod === 'wechat' ? 'is-active' : ''}}" data-method="wechat" bindtap="onPayMethodSelect">
            <image class="wxzf" src="{{ossUrl}}/images/微信支付.svg"></image>
            <text class="pay-name">微信支付</text>
          </view>
      </view>

    </block>
    <block wx:else>
      <view class="empty-block">
        <t-empty description="暂无可用套餐" />
      </view>
    </block>
  </view>

  <view class="pay-bar" wx:if="{{packages.length}}">
    <view class="pay-action {{agreementChecked && selectedPayMethod && selectedPackageId ? '' : 'is-disabled'}}" data-id="{{selectedPackageId}}" bindtap="onPurchaseTap">
      <view class="pay-price">
        <text class="pay-currency">￥</text>
        <block wx:for="{{packages}}" wx:key="package_id">
          <text wx:if="{{item.package_id === selectedPackageId}}" class="pay-amount">{{item.priceLabel}}</text>
        </block>
      </view>
      <text class="pay-text">立即支付</text>
    </view>
    <view class="section agreement" bindtap="onAgreementToggle">
      <view class="agreement-check {{agreementChecked ? 'is-checked' : ''}}"></view>
      <text class="agreement-text">同意并接受会员服务协议与隐私政策</text>
    </view>
  </view>
</view>
