/* reportSelector.wxss — 数企云检报告选择页样式
   现在采用浅色系卡片风格，与各报告页保持一致
*/

.page {
  min-height: 100vh;
  background: #f4f6fb;
  padding: 24rpx 28rpx 60rpx;
  box-sizing: border-box;
}

/* 页头 */
.header {
  padding: 20rpx 0 28rpx;
  text-align: center;
}

.header-en {
  display: block;
  font-size: 18rpx;
  color: #5c6cff;
  letter-spacing: 5rpx;
  margin-bottom: 8rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #182132;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  color: #5c6371;
}

/* 卡片列表 */
.cards {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 单张报告卡片：与其他页面卡片风格接近 */
.report-card {
  position: relative;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0;
  box-shadow: 0 10rpx 24rpx rgba(20, 30, 50, 0.08);
  overflow: hidden;
}

.card--hover {
  background: #f7f9ff;
}

/* 左侧色条 */
.card-accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  border-radius: 16rpx 0 0 16rpx;
}

.accent--blue   { background: linear-gradient(180deg, #165dff, #69b3ff); }
.accent--teal   { background: linear-gradient(180deg, #00b96b, #52e5a4); }
.accent--orange { background: linear-gradient(180deg, #ff6b35, #ffb347); }

/* 卡片内容区域 */
.card-body {
  display: flex;
  align-items: center;
  padding: 36rpx 30rpx 36rpx 34rpx;
  gap: 20rpx;
}

/* 图标框 */
.card-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-box--blue   { background: #f0f5ff; border: 1rpx solid #c5d8ff; }
.icon-box--teal   { background: #e6f8f0; border: 1rpx solid #9fe5c7; }
.icon-box--orange { background: #fff3e8; border: 1rpx solid #ffd2a8; }

.card-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.card-icon-char {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2a3a;
}

/* 文字区 */
.card-meta {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #182132;
}

.card-badge {
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}

.badge--green {
  color: #00b96b;
  background: #e7f8ef;
  border: 1rpx solid #a5e4c6;
}

.badge--blue {
  color: #165dff;
  background: #edf4ff;
  border: 1rpx solid #b4c8ff;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #5c6371;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 18rpx;
  color: #8b93a5;
  background: #f3f5fb;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

/* 右箭头 */
.card-arrow {
  font-size: 40rpx;
  color: #c0c5d3;
  flex-shrink: 0;
  margin-left: 4rpx;
  line-height: 1;
}

/* 底部提示 */
.footer-tip {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #8b93a5;
  margin-top: 20rpx;
}
