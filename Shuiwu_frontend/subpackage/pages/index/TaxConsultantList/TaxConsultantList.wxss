/**
 * TaxConsultantList.wxss — 税务师列表页面样式
 *
 * 功能：
 *   - 简洁的白色和蓝色设计
 *   - 整齐的信息布局
 *   - 清晰的视觉层次
 */

/* ==================== 容器 ==================== */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ==================== 背景装饰 ==================== */
.bg-decoration {
  display: none;
}

/* ==================== 顶部操作栏 ==================== */
.header-section {
  width: 100%;
  background-color: #ffffff;
  padding: 32rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #6b7280;
}

.header-action {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

/* 申请入驻按钮 */
.apply-btn {
  padding: 14rpx 32rpx;
  background-color: #3B55F3;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 8rpx;
  border: none;
}

.apply-btn::after {
  border: none;
}

.apply-btn:active {
  opacity: 0.85;
}

/* 状态标识 */
.status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background-color: #EFF6FF;
  border: 1rpx solid #3B55F3;
  border-radius: 8rpx;
}

.status-badge.status-pending {
  background-color: #FFF7ED;
  border-color: #FF9800;
}

.badge-icon {
  font-size: 22rpx;
  color: #3B55F3;
  font-weight: bold;
}

.badge-text {
  font-size: 26rpx;
  color: #3B55F3;
  font-weight: 500;
}

.status-badge.status-pending .badge-text {
  color: #FF9800;
}

/* ==================== 列表区域 ==================== */
.list-section {
  width: 100%;
  padding: 24rpx 30rpx;
  box-sizing: border-box;
}

.accountant-card {
  width: 100%;
  position: relative;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #ffffff;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.accountant-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 卡片装饰线 */
.card-accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background-color: #3B55F3;
}

/* 卡片内容 */
.card-content {
  padding: 28rpx 28rpx 28rpx 32rpx;
  box-sizing: border-box;
}

/* 姓名区域 */
.name-section {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.name-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.accountant-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.name-badge {
  padding: 4rpx 12rpx;
  background-color: #EFF6FF;
  border: 1rpx solid #3B55F3;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #3B55F3;
  font-weight: 600;
}

/* 通用区块样式 */
.contact-section,
.specialty-section,
.cert-section,
.intro-section {
  margin-bottom: 20rpx;
}

.contact-section:last-child,
.specialty-section:last-child,
.cert-section:last-child,
.intro-section:last-child {
  margin-bottom: 0;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.label-icon {
  font-size: 24rpx;
}

.label-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

/* 联系方式 */
.phone-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.phone-number {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
  font-family: 'SF Mono', 'Monaco', monospace;
}

.phone-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.action-btn {
  padding: 8rpx 16rpx;
  background-color: #f3f4f6;
  border: 1rpx solid #e5e7eb;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

.action-btn.primary {
  background-color: #3B55F3;
  border-color: #3B55F3;
  color: #ffffff;
}

.action-btn:active {
  opacity: 0.7;
}

/* 专长领域 */
.specialty-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.specialty-tag {
  padding: 6rpx 16rpx;
  background-color: #EFF6FF;
  border: 1rpx solid #3B55F3;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #3B55F3;
  font-weight: 500;
}

/* 证书编号 */
.cert-number {
  font-size: 26rpx;
  color: #374151;
  font-family: 'SF Mono', 'Monaco', monospace;
}

/* 个人简介 */
.intro-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.8;
  word-break: break-all;
}

/* ==================== 空状态 ==================== */
.empty-state {
  width: 100%;
  padding: 160rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ==================== 加载状态 ==================== */
.loading-state {
  width: 100%;
  padding: 120rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #e5e7eb;
  border-top-color: #3B55F3;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}

/* ==================== 加载更多 ==================== */
.load-more {
  width: 100%;
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.load-more-line {
  flex: 1;
  height: 1rpx;
  background-color: #e5e7eb;
}

.load-more-text {
  font-size: 24rpx;
  color: #9ca3af;
}
