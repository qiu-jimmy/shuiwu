  }
}

/* 第4个字"享" - 37.5-50%变金色，87.5-100%变白色 */
.char-3 {
  animation: charColorCycle3 2.4s linear infinite;
}

@keyframes charColorCycle3 {
  0%, 37.5% {
    color: #ffffff;
    text-shadow: 
