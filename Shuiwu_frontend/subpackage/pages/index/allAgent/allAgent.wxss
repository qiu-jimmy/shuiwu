/* ========== 底部填充：线条 + 渐变 + 粒子（填满下方空白） ========== */
.tech-bottom-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 420rpx;
  pointer-events: none;
  overflow: hidden;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(187, 222, 251, 0.25) 30%,
    rgba(144, 202, 249, 0.4) 70%,
    rgba(100, 181, 246, 0.35) 100%
  );
}

/* 填充横线：均匀铺满底部 */
.tech-fill-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(59, 85, 243, 0.12) 20%,
    rgba(100, 181, 246, 0.2) 50%,
    rgba(59, 85, 243, 0.12) 80%,
    transparent 100%
  );
}
.tech-fill-line--1 { bottom: 28rpx; opacity: 0.9; }
.tech-fill-line--2 { bottom: 68rpx; opacity: 0.75; }
.tech-fill-line--3 { bottom: 108rpx; opacity: 0.65; }
.tech-fill-line--4 { bottom: 148rpx; opacity: 0.55; }
.tech-fill-line--5 { bottom: 188rpx; opacity: 0.45; }
.tech-fill-line--6 { bottom: 228rpx; opacity: 0.35; }
.tech-fill-line--7 { bottom: 268rpx; opacity: 0.28; }
.tech-fill-line--8 { bottom: 308rpx; opacity: 0.2; }
.tech-fill-line--9 { bottom: 348rpx; opacity: 0.15; }
.tech-fill-line--10 { bottom: 388rpx; opacity: 0.1; }

.tech-particle-scene {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 260rpx;
  pointer-events: none;
  overflow: visible;
  z-index: 1;
}

/* 中心：企业核心（稍大、柔和光晕） */
.tech-particle-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  margin-top: -14rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle at 30% 30%,
    rgba(255, 255, 255, 0.95),
    rgba(100, 181, 246, 0.9) 40%,
    rgba(59, 85, 243, 0.85)
  );
  box-shadow:
    0 0 24rpx rgba(59, 85, 243, 0.7),
    0 0 48rpx rgba(100, 181, 246, 0.35);
  animation: particleCorePulse 2.5s ease-in-out infinite;
}

@keyframes particleCorePulse {
  0%, 100% { opacity: 0.9; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

/* 周围：智能体粒子（一圈 + 错开呼吸） */
.tech-particle {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  margin-left: -7rpx;
  margin-top: -7rpx;
  border-radius: 50%;
  background: rgba(100, 181, 246, 0.95);
  box-shadow: 0 0 16rpx rgba(59, 85, 243, 0.6);
  animation: particleFloat 3s ease-in-out infinite;
}
.tech-particle--outer {
  width: 10rpx;
  height: 10rpx;
  margin-left: -5rpx;
  margin-top: -5rpx;
  background: rgba(59, 85, 243, 0.7);
  box-shadow: 0 0 12rpx rgba(59, 85, 243, 0.4);
  animation-duration: 3.5s;
}

/* 内圈 12 粒：围绕中心成圆 */
.tech-particle--1 { left: 68%; top: 50%; animation-delay: 0s; }
.tech-particle--2 { left: 64%; top: 62%; animation-delay: 0.25s; }
.tech-particle--3 { left: 50%; top: 68%; animation-delay: 0.5s; }
.tech-particle--4 { left: 36%; top: 62%; animation-delay: 0.75s; }
.tech-particle--5 { left: 32%; top: 50%; animation-delay: 1s; }
.tech-particle--6 { left: 36%; top: 38%; animation-delay: 1.25s; }
.tech-particle--7 { left: 50%; top: 32%; animation-delay: 1.5s; }
.tech-particle--8 { left: 64%; top: 38%; animation-delay: 1.75s; }
.tech-particle--9 { left: 76%; top: 44%; animation-delay: 0.15s; }
.tech-particle--10 { left: 76%; top: 56%; animation-delay: 0.4s; }
.tech-particle--11 { left: 24%; top: 56%; animation-delay: 0.65s; }
.tech-particle--12 { left: 24%; top: 44%; animation-delay: 0.9s; }

/* 外圈 4 粒：更远、更淡 */
.tech-particle--o1 { left: 82%; top: 50%; animation-delay: 0.2s; }
.tech-particle--o2 { left: 50%; top: 78%; animation-delay: 0.6s; }
.tech-particle--o3 { left: 18%; top: 50%; animation-delay: 1s; }
.tech-particle--o4 { left: 50%; top: 22%; animation-delay: 1.4s; }

@keyframes particleFloat {
  0%, 100% {
    opacity: 0.6;
    transform: scale(0.92) translateY(0);
  }
  50% {
    opacity: 1;
    transform: scale(1.1) translateY(-6rpx);
  }
}
