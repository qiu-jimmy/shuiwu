/* pages/index/TaxConsultantInput/TaxConsultantInput.wxss */

.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.form-wrapper {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
}

/* ==================== 表单区块 ==================== */
.form-section {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.add-btn {
  font-size: 28rpx;
  color: #3B55F3;
  font-weight: normal;
  padding: 8rpx 16rpx;
  border: 2rpx solid #3B55F3;
  border-radius: 8rpx;
}

/* ==================== 表单项 ==================== */
.form-item {
  width: 100%;
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  line-height: 1.5;
}

.form-label-tip {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 8rpx;
}

.required {
  color: #ff4444;
  margin-right: 4rpx;
}

/* ==================== 输入框 ==================== */
.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input:focus {
  background-color: #fff;
  border-color: #3B55F3;
}

/* ==================== 文本域 ==================== */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  line-height: 1.6;
}

.form-textarea:focus {
  background-color: #fff;
  border-color: #3B55F3;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

/* ==================== 选择器 ==================== */
.picker-view {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.picker-view-small {
  flex: 1;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #999;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
  transform: rotate(90deg);
}

/* ==================== 日期范围选择 ==================== */
.date-range {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-separator {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

/* ==================== 文件上传 ==================== */
.upload-wrapper {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.upload-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  z-index: 10;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.upload-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.form-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* ==================== 工作经历 ==================== */
.experience-list {
  width: 100%;
}

.experience-item {
  width: 100%;
  padding: 30rpx;
  background-color: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.experience-item:last-child {
  margin-bottom: 0;
}

.experience-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.experience-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.experience-delete {
  font-size: 26rpx;
  color: #ff4444;
  padding: 8rpx 16rpx;
  border: 2rpx solid #ff4444;
  border-radius: 8rpx;
}

/* ==================== 承诺文本 ==================== */
.commitment-text {
  width: 100%;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.commitment-text text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.commitment-text text:last-child {
  margin-bottom: 0;
}

/* ==================== 提交提示 ==================== */
.submit-tip {
  width: 100%;
  padding: 30rpx;
  margin: 10rpx 10rpx;
  box-sizing: border-box;
  background-color: #E6F2FF;
  border-left: 6rpx solid #3B55F3;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.submit-tip-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.submit-tip-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  flex: 1;
  text-align: left;
  font-weight: 500;
}

/* ==================== 提交按钮 ==================== */
.submit-wrapper {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  position: sticky;
  bottom: 0;
  background-color: #f5f5f5;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #3B55F3 0%, #2B45E3 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(59, 85, 243, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn-disabled {
  background: #d0d0d0 !important;
  color: #999 !important;
  box-shadow: none !important;
  opacity: 1 !important;
}

.submit-btn-disabled:active {
  opacity: 1 !important;
}

/* ==================== 承诺确认协议 ==================== */
.agreement-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 30rpx;
  color: #666;
  font-size: 24rpx;
}

.agreement-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  border: 2rpx solid #c6ccda;
  background: #ffffff;
  position: relative;
  box-sizing: border-box;
  flex-shrink: 0;
}

.agreement-check.is-checked {
  border-color: #3B55F3;
  background: #3B55F3;
}

.agreement-check.is-checked::after {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 5rpx;
  width: 7rpx;
  height: 14rpx;
  border-right: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(45deg);
}

.agreement-text {
  flex: 1;
  line-height: 1.6;
}
