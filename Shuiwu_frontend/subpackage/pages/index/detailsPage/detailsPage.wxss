/* pages/index/detailsPage/detailsPage.wxss */
.container {
  width: 100%;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.case-header {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 0;
}

.case-type-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #3B55F3;
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
}

.case-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.5;
}

.section {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #3B55F3;
}

.section-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.lessons-list {
  display: flex;
  flex-direction: column;
}

.lesson-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.lesson-item:last-child {
  border-bottom: none;
}

.lesson-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.laws-list {
  display: flex;
  flex-direction: column;
}

.law-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.law-item:last-child {
  border-bottom: none;
}

.law-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.law-articles {
  display: flex;
  flex-direction: column;
  padding-left: 20rpx;
}

.article-item {
  padding: 10rpx 0;
}

.article-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.empty-state {
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
}

/* 法律知识专用样式 */
.law-info-item {
  padding: 10rpx 0;
  display: flex;
  flex-direction: row;
}

.info-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  min-width: 160rpx;
}

.info-content {
  font-size: 28rpx;
  color: #666666;
  flex: 1;
  line-height: 1.6;
}

.chapters-list {
  display: flex;
  flex-direction: column;
}

.chapter-item {
  margin-bottom: 30rpx;
}

.chapter-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.articles-list {
  display: flex;
  flex-direction: column;
}

.article-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-no {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #3B55F3;
  margin-bottom: 10rpx;
}

.article-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.content-sections-list {
  display: flex;
  flex-direction: column;
}

.content-section-item {
  margin-bottom: 30rpx;
}

.content-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #3B55F3;
}

.subsections-list {
  display: flex;
  flex-direction: column;
}

.subsection-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.subsection-item:last-child {
  border-bottom: none;
}

.subsection-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.subsection-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.supplementary-info {
  display: flex;
  flex-direction: column;
}