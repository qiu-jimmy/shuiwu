          <image class="card-icon" src="{{ossUrl}}/images/input/input2.png" mode="aspectFit"></image>
        </view>
        <text class="card-text">智能税务申报</text>
      </view>
      <view class="card-item-empty"></view>
      <view class="card-item-empty"></view>
    </view>
  </view>

