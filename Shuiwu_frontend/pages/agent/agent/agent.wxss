/* pages/agent/agent/agent.wxss */
.ai-notice {
  text-align: center;
  font-size: 20rpx;
  color: #999;
  padding: 8rpx 0;
}

.page {
  padding: 32rpx 28rpx 140rpx;
}

.item-bar {
  position: sticky;
  top: 0;
  background-color: rgba(248, 250, 252, 0.86);
  padding: 16rpx 24rpx;
  margin: 0 12rpx;
  border-radius: 0 0 24rpx 24rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.10);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab {
  padding: 0 28rpx 0 28rpx;
  display: flex;
  align-items: center;
}

.chat {
  position: relative;
  height: 50rpx;
  font-weight: 700;
  font-size: 34rpx;
  color: #0f172a;
  letter-spacing: 2rpx;
  padding-bottom: 10rpx;
}

.chat::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 2rpx;
  width: 100%;
  height: 6rpx;
  border-radius: 999rpx;
  background: #3b55f3;
}

.tabs-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tab-pane {
  padding-top: 16rpx;
}

.section-title {
  display: block;
  margin: 24rpx 0 12rpx 20rpx;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 700;
  letter-spacing: 1.5rpx;
}

.section-group {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 20rpx 40rpx rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  padding: 34rpx 22rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
  transition: background-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
}

.list-item-last {
  border-bottom: none;
}

.list-item:active {
  background-color: rgba(99, 102, 241, 0.06);
  transform: translateY(2rpx);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 500rpx;
}

.list-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.list-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #667085;
}

.list-actions {
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.list-actions view {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 12rpx 26rpx rgba(15, 23, 42, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.list-actions view:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.12);
}

.empty-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-52%);
  text-align: center;
  width: 72%;
  padding: 48rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
}

.empty-image{
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 10rpx 18rpx rgba(59, 130, 246, 0.25));
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: 48rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  
  box-shadow: 0 16rpx 30rpx rgba(59, 85, 243, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.fab:active {
  transform: translateY(3rpx) scale(0.98);
  box-shadow:
    0 12rpx 24rpx rgba(79, 70, 229, 0.32),
    0 6rpx 14rpx rgba(245, 158, 11, 0.2);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
}

@media (prefers-reduced-motion: reduce) {
  .list-item,
  .list-actions view,
  .fab {
    transition: none;
  }
}
