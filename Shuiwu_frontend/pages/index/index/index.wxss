/* pages/index/index/index.wxss */

/* ==================== 容器样式 ==================== */
.container {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 0;
  padding-bottom: 0; /* 确保底部没有额外间距 */
  margin-bottom: 0; /* 确保底部没有额外间距 */
  box-sizing: border-box;
  background-color: #f8fafc;
  background-image:
    radial-gradient(120% 80% at 12% -8%, rgba(99, 102, 241, 0.16), transparent 55%),
    radial-gradient(120% 80% at 92% 0%, rgba(245, 158, 11, 0.14), transparent 55%),
    linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}


/* ==================== 背景图片相关 ==================== */
.home-bg-container {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.home-bg {
  width: 100%;
  height: auto;
  display: block;
}

/* ==================== 标语样式 ==================== */
.slogan-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  padding-top: 255rpx;
  padding-left: 30rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.slogan-text {
  color: #ffffff;
  font-weight: bold;
  font-size: 48rpx;
  display: block;
  line-height: 1.5;
}

/* ==================== 内容区域容器 ==================== */
.content-wrapper {
  width: 100%;
  /* flex: 1 移除，改用明确的高度（通过内联样式设置） */
  min-height: 60vh; /* 最小高度，确保容器有足够空间 */
  margin-top: -20rpx;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 20rpx;
  background-color: #f8fafc;
  background-image:
    radial-gradient(120% 80% at 12% -8%, rgba(99, 102, 241, 0.16), transparent 55%),
    radial-gradient(120% 80% at 92% 0%, rgba(245, 158, 11, 0.14), transparent 55%),
    linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  overflow: hidden; /* 改回 hidden，避免产生滚动条 */
  position: relative;
  z-index: 9;
}

/* ==================== 通知栏样式 ==================== */
.notice-bar {
  width: calc(100% - 60rpx);
  margin: 30rpx 30rpx 20rpx 30rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(59, 130, 246, 0.12) 50%, rgba(147, 197, 253, 0.15) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
  box-shadow: 
    0 8rpx 24rpx rgba(99, 102, 241, 0.12),
    0 2rpx 8rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: transform 200ms ease, box-shadow 200ms ease;
  position: relative;
  z-index: 999;
}

.notice-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
  pointer-events: none;
}

.notice-bar:active {
  transform: translateY(1rpx);
  box-shadow: 
    0 4rpx 16rpx rgba(99, 102, 241, 0.1),
    0 1rpx 4rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

.notice-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 2rpx 4rpx rgba(99, 102, 241, 0.2));
}

.notice-text-wrapper {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  position: relative;
}

.notice-text {
  display: inline-block;
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  animation: scroll-text linear infinite;
  padding-left: 100%;
  white-space: nowrap;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

@keyframes scroll-text {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-100%);
  }
}

/* ==================== 通知详情弹窗样式 ==================== */
.notice-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.notice-modal-content {
  width: 100%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
}

.notice-modal-header {
  width: 100%;
  padding: 30rpx;
  background-color: #E6F2FF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.notice-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.notice-modal-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.close-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.notice-modal-body {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
}

.notice-modal-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-line;
  display: block;
}




