.privacy-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 32rpx 24rpx;
}

.privacy-container {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
}

.privacy-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.privacy-section {
  margin-bottom: 32rpx;
}

.privacy-section:last-child {
  margin-bottom: 0;
}

.privacy-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.privacy-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 12rpx;
  text-align: justify;
}

.contact-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.wechat-id {
  color: #3B55F3;
  margin: 0 8rpx;
}

.copy-hint {
  font-size: 22rpx;
  color: #999999;
}

.privacy-footer {
  margin-top: 48rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eeeeee;
  text-align: center;
}

.update-date {
  font-size: 24rpx;
  color: #999999;
}
