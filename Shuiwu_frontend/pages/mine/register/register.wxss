/**
 * 注册页面样式
 *
 * 功能说明：
 * - 定义注册表单样式
 * - 定义邀请码输入框及自动填充提示样式
 */

.page {
  padding: 20rpx;
}

.card {
  padding: 28rpx 26rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.card-header {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.form {
  margin-top: 22rpx;
}

.form-item {
  margin-top: 16rpx;
  position: relative;
}

.form-item:first-child {
  margin-top: 0;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input:focus {
  background: #ffffff;
}

/* 邀请码输入框样式 */
.invite-code-item .input {
  padding-right: 180rpx;
}

.auto-fill-tip {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #10b981;
  background: #d1fae5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.actions {
  margin-top: 24rpx;
}

.login-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
}
