<!--pages/mine/login/login.wxml-->
<view class="page">
  <view class="card">
    <view class="card-header">
      <text class="card-title">微信快捷登录</text>
      <text class="card-desc">登录后同步你的税务档案与工具</text>
    </view>

    <!-- 手机号密码登录 -->
    <view class="form" wx:if="{{is_show}}">
      <view class="form-item">
        <t-input
          label="手机号"
          layout="vertical"
          placeholder="请输入 11 位手机号"
          type="number"
          maxlength="11"
          clearable
          value="{{form.username}}"
          data-field="username"
          bind:change="onInputChange"
        />
      </view>
      <view class="form-item">
        <t-input
          label="密码"
          layout="vertical"
          placeholder="请输入登录密码"
          type="password"
          value="{{form.password}}"
          data-field="password"
          bind:change="onInputChange"
        />
      </view>
      <view class="form-item" wx:if="{{is_show}}">
        <t-button
          theme="primary"
          block
          loading="{{loading}}"
          disabled="{{loading}}"
          bind:tap="onSubmit"
        >登录</t-button>
      </view>
    </view>

    <!-- 协议勾选 -->
    <view class="agreement-wrapper">
      <label class="agreement-label" bindtap="onAgreementToggle">
        <checkbox value="agreement" checked="{{agreementChecked}}" />
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="onAgreementTap">《用户协议》</text>
        <text>和</text>
        <text class="agreement-link" bindtap="onPrivacyTap">《隐私政策》</text>
      </label>
    </view>

    <!-- 微信快捷登录 -->
    <view class="wechat-login">
      <t-button
        theme="success"
        variant="outline"
        block
        loading="{{wxLoading}}"
        disabled="{{wxLoading}}"
        icon="logo-wechat"
        bind:tap="onWechatLogin"
      >微信快捷登录</t-button>
    </view>

    <!-- 注册入口已隐藏 -->
    <view class="helper" wx:if="{{is_show}}">
      <text class="helper-text">还没有账号？</text>
      <t-link
        content="去注册"
        theme="primary"
        size="small"
        navigator-props="{{ { url: '/pages/mine/register/register', openType: 'navigate' } }}"
      />
    </view>
  </view>

</view>
