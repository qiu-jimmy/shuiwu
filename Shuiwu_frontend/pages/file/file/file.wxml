<!--pages/file/file/file.wxml-->
<view class="container">
  <view class="page-bg">
    <view class="bg-orb bg-orb-1"></view>
    <view class="bg-orb bg-orb-2"></view>
    <view class="bg-orb bg-orb-3"></view>
  </view>
  <view class="page-content">
    <!-- 预览文件组件 -->
    <preview-file id="preview-file"></preview-file>
    <view class="page-shell">
      <!-- 知识库卡片 -->
      <view class="knowledge-card" bindtap="onKnowledgeBaseTap">
        <view class="card-sheen"></view>
        <view class="knowledge-card-content">
          <text class="knowledge-card-title">点击进入·知识库</text>
          <text class="knowledge-card-subtitle">智能知识库・赋能政务新体验</text>
        </view>
      </view>
      <!-- 筛选区域 -->
      <view class="filter-container">
        <!-- 文件类型选择 -->
        <view class="filter-section" bindtap="onFileTypeTap">
          <text class="filter-label">文件类型：</text>
          <text class="filter-value">{{selectedFileType}}</text>
          <text class="arrow-down"></text>
        </view>
        <view class="filter-divider"></view>
        <!-- 文件数量 -->
        <view class="filter-count-section">
          <text class="filter-label">文件数：</text>
          <text class="filter-count">{{categoryCount}}</text>
        </view>
      </view>

      <!-- 文件列表 -->
      <view class="file-list">
        <!-- 未登录状态 -->
        <view class="empty-state" wx:if="{{!isLoggedIn}}">
          <view class="empty-content">
            <view class="empty-line">
              <text class="empty-text">还未登录，</text>
              <text class="empty-link" bindtap="navigateToLogin">请登录</text>
            </view>
          </view>
        </view>

        <!-- 已登录但无文件 -->
        <view class="empty-state" wx:elif="{{isLoggedIn && !hasFiles}}">
          <image class="empty-image" src="{{ossUrl}}/images/nothing.png" mode="aspectFit"/>
          <view class="empty-content">
            <text class="empty-text">还没有上传文件，快去上传吧</text>
          </view>
        </view>

        <!-- 有文件列表 -->
        <file-list 
          wx:elif="{{isLoggedIn && hasFiles}}"
          file-list="{{fileList}}"
          bind:listchange="onFileListChange"
          bind:filetap="onFileTap"
          bind:delete="onDeleteFile">
        </file-list>
      </view>
    </view>
    <!-- 固定添加按钮 -->
    <view class="add-button" bindtap="onAddTap">
      <t-icon name="add" size="24" color="#ffffff" />
    </view>
  </view>
</view>
