/* pages/file/component/myKnowledge/myKnowledge.wxss */

.my-knowledge-container {
  width: 100%;
}

/* ==================== 筛选区域 ==================== */
.filter-container {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-top: 30rpx;
  gap: 30rpx;
  box-sizing: border-box;
}

.filter-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
}

.filter-count-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  flex-shrink: 0;
}

.filter-count {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ==================== 未登录提示 ==================== */
.login-tip {
  width: 100%;
  padding: 60rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
}

.login-tip-text {
  font-size: 28rpx;
  color: #999;
}

/* ==================== 空状态 ==================== */
.empty-state {
  width: 100%;
  padding: 100rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 30rpx;
}

.empty-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* ==================== 文件列表 ==================== */
.file-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.file-item-wrapper {
  width: 100%;
  position: relative;
  overflow: hidden;
  margin-bottom: 2rpx;
}

.file-card {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 30rpx 0 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08), 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
  box-sizing: border-box;
  position: relative;
  overflow: visible;
  transition: transform 0.3s ease;
  z-index: 1;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  color: #FF4444;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 0;
}

.file-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
}

.add-btn {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background-color: transparent;
  color: #3B55F3;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.file-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.file-doc-count {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* ==================== 添加文件弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn-cancel {
  padding: 20rpx 40rpx;
  background-color: #F5F5F5;
  color: #666;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.btn-submit {
  padding: 20rpx 40rpx;
  background-color: #3B55F3;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.btn-submit[disabled] {
  background-color: #CCCCCC;
  color: #999;
}

/* 知识库信息区域 */
.kb-info-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 文件列表区域 */
.file-list-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.file-list-container {
  max-height: 400rpx;
  overflow-y: auto;
}

.file-item-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #F9F9F9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.file-item-content {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 20rpx;
}

.file-icon-select {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.file-info-select {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.file-name-select {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.file-meta-select {
  font-size: 24rpx;
  color: #999;
}

.checkbox-wrapper {
  flex-shrink: 0;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}

.checkbox.checked {
  background-color: #3B55F3;
  border-color: #3B55F3;
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.empty-file-state {
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-file-text {
  font-size: 28rpx;
  color: #999;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.select-all-wrapper {
  display: flex;
  align-items: center;
}

.select-all-text {
  font-size: 26rpx;
  color: #3B55F3;
  font-weight: 500;
}

.upload-new-file-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #3B55F3 0%, #5B6EF7 100%);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 85, 243, 0.3);
}

.upload-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.upload-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.upload-new-file-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ==================== 文档列表弹窗 ==================== */
.doc-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.doc-modal-content {
  width: 100%;
  max-width: 700rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.2);
  display: flex;
  flex-direction: column;
}

.doc-modal-header {
  width: 100%;
  padding: 30rpx;
  background-color: #E6F2FF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f0f0f0;
}

.doc-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.doc-modal-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.close-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.doc-modal-body {
  width: 100%;
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.doc-count-info {
  width: 100%;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.doc-count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}
