/* pages/file/component/addKnowledge/addKnowledge.wxss */

/* 遮罩层 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗内容 */
.modal-content {
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 弹窗头部 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗主体 */
.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #F5F7FB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #F5F7FB;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-content {
  width: 100%;
  height: 80rpx;
  background-color: #F5F7FB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  margin-top: -35rpx;
  flex: 1;
}

.picker-placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 20rpx;
}

.picker-arrow::after {
  content: '';
  display: inline-block;
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 6px solid currentColor; /* 倒三角的关键 */
  margin-left: 6px;
  vertical-align: middle;
}

.form-value {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  background-color: #F5F7FB;
  border-radius: 12rpx;
}

/* 弹窗底部 */
.modal-footer {
  display: flex;
  padding: 24rpx 30rpx 30rpx;
  border-top: 1rpx solid #F0F0F0;
  gap: 20rpx;
  background-color: #fff;
}

.btn-cancel,
.btn-submit {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.btn-cancel {
  background-color: #F5F7FB;
  color: #666;
  border: 1rpx solid #E5E7EB;
}

.btn-cancel:active {
  background-color: #E5E7EB;
  opacity: 0.9;
}

.btn-submit {
  background: linear-gradient(135deg, #3B55F3 0%, #2B45E3 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(59, 85, 243, 0.25);
}

.btn-submit:active {
  opacity: 0.85;
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(59, 85, 243, 0.2);
}

.btn-submit[disabled] {
  background: #E5E7EB !important;
  color: #9CA3AF !important;
  box-shadow: none !important;
  opacity: 1 !important;
  transform: none !important;
}

.btn-submit[disabled]:active {
  opacity: 1 !important;
  transform: none !important;
}

.btn-cancel::after,
.btn-submit::after {
  border: none;
}
